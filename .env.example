# Alpaca API (paper)
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_PAPER=true

# Underlyings
SYMBOLS=AAPL,TSLA,META

# Contract selection
TARGET_DELTA=0.40
DELTA_TOLERANCE=0.15
DEFAULT_IV=0.30
MIN_DTE=1
MAX_DTE=10
MAX_SPREAD_PCT=8

# Sizing / exits (premium-based)
PREMIUM_PER_TRADE=500
TAKE_PROFIT_PCT=30
STOP_LOSS_PCT=15
MAX_HOLD_MINUTES=20

# Risk
MAX_POSITIONS=2
MAX_DAILY_LOSS_USD=200
MAX_TRADES_PER_DAY=15

# Signals
VWAP_MIN_DISTANCE_PCT=0.05
VOLUME_SPIKE_MULT=2.0
MOMENTUM_LOOKBACK=5
ORB_MINUTES=15
ORB_CUTOFF=11:00

# Session (ET)
TRADE_START=09:35
NO_NEW_ENTRIES_AFTER=14:45
FLAT_BY=15:30
POLL_SECONDS=15

# Discord alerts (optional)
DISCORD_WEBHOOK_URL=
